<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtFacultyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"/>

        <TextView
            android:id="@+id/txtFacultyCabin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cabin Number"
            android:textColor="#7F8C8D"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/txtFacultyEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#3498DB"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnCall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Call Staff"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="5dp"/>

            <Button
                android:id="@+id/btnMsg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="WhatsApp"
                android:backgroundTint="#25D366"/>

        </LinearLayout> <!-- Added missing closing tag for inner horizontal layout -->
    </LinearLayout> <!-- Added missing closing tag for outer vertical layout -->
</androidx.cardview.widget.CardView>